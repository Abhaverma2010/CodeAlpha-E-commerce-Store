<!-- views/cart/index.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | ShopEase</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="container mt-4">
    <h1 class="page-title">🛒 My Cart</h1>

    <% if (cart.length === 0) { %>
      <div class="empty-state">
        <p>Your cart is empty.</p>
        <a href="/products" class="btn btn-primary mt-2">Start Shopping</a>
      </div>
    <% } else { %>
      <div class="cart-layout">
        <!-- Cart Items -->
        <div class="cart-items">
          <% cart.forEach(item => { %>
            <% if (item.product) { %>
              <div class="cart-item">
                <img src="<%= item.product.image %>" alt="<%= item.product.name %>" class="cart-item-img" />
                <div class="cart-item-info">
                  <h3><a href="/products/<%= item.product._id %>"><%= item.product.name %></a></h3>
                  <p class="cart-item-price">₹<%= item.product.price.toLocaleString('en-IN') %> × <%= item.quantity %></p>
                  <p class="cart-item-subtotal">Subtotal: ₹<%= (item.product.price * item.quantity).toLocaleString('en-IN') %></p>
                </div>
                <form action="/cart/remove/<%= item.product._id %>" method="POST">
                  <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                </form>
              </div>
            <% } %>
          <% }) %>
        </div>

        <!-- Order Summary -->
        <div class="cart-summary">
          <h2>Order Summary</h2>
          <div class="summary-row">
            <span>Items (<%= cart.length %>)</span>
            <span>₹<%= total.toLocaleString('en-IN') %></span>
          </div>
          <div class="summary-row">
            <span>Shipping</span>
            <span class="free">FREE</span>
          </div>
          <div class="summary-total">
            <span>Total</span>
            <span>₹<%= total.toLocaleString('en-IN') %></span>
          </div>
          <a href="/orders/checkout" class="btn btn-primary full-width btn-lg">Proceed to Checkout →</a>
          <a href="/products" class="btn btn-outline full-width mt-2">Continue Shopping</a>
        </div>
      </div>
    <% } %>
  </div>

  <footer class="footer"><p>© 2024 ShopEase</p></footer>
  <script src="/js/main.js"></script>
</body>
</html>
