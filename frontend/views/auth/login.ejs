<!-- views/auth/login.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | ShopEase</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="auth-container">
    <div class="auth-card">
      <h1>Welcome Back</h1>
      <p class="auth-subtitle">Login to your ShopEase account</p>

      <form action="/auth/login" method="POST" class="auth-form">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="abha@example.com" required />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="Your password" required />
        </div>

        <button type="submit" class="btn btn-primary full-width btn-lg">Login</button>
      </form>

      <p class="auth-footer">
        Don't have an account? <a href="/auth/register">Register here</a>
      </p>

      <!-- For demo/testing only -->
      <!-- <div class="demo-hint">
        <p>💡 <strong>Demo Tip:</strong> Register first, then make your first user an admin by running this in MongoDB shell:</p>
        <code>db.users.updateOne({email:"your@email.com"}, {$set:{role:"admin"}})</code>
      </div> -->
    </div>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
