<!-- views/orders/checkout.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Checkout | ShopEase</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('../partials/navbar') %>
  <%- include('../partials/flash') %>

  <div class="container mt-4">
    <h1 class="page-title">Checkout</h1>

    <div class="checkout-layout">
      <!-- Shipping Address Form -->
      <div class="checkout-form-section">
        <form action="/orders/place" method="POST">
          <h2>Shipping Address</h2>

          <div class="form-group">
            <label>Street Address</label>
            <input type="text" name="street" placeholder="123 MG Road, Apartment 4B" required />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>City</label>
              <input type="text" name="city" placeholder="Indore" required />
            </div>
            <div class="form-group">
              <label>State</label>
              <input type="text" name="state" placeholder="Madhya Pradesh" required />
            </div>
          </div>
          <div class="form-group">
            <label>PIN Code</label>
            <input type="text" name="pincode" placeholder="452001" pattern="[0-9]{6}" required />
          </div>

          <h2 class="mt-4">Payment Method</h2>
          <div class="payment-options">
            <label class="radio-option">
              <input type="radio" name="paymentMethod" value="COD" checked /> Cash on Delivery
            </label>
            <label class="radio-option">
              <input type="radio" name="paymentMethod" value="Online" /> Online Payment
            </label>
          </div>

          <button type="submit" class="btn btn-primary btn-lg full-width mt-4">
            Place Order — ₹<%= total.toLocaleString('en-IN') %>
          </button>
        </form>
      </div>

      <!-- Order Review -->
      <div class="checkout-summary">
        <h2>Your Order</h2>
        <% cart.forEach(item => { %>
          <% if (item.product) { %>
            <div class="checkout-item">
              <span><%= item.product.name %> × <%= item.quantity %></span>
              <span>₹<%= (item.product.price * item.quantity).toLocaleString('en-IN') %></span>
            </div>
          <% } %>
        <% }) %>
        <div class="checkout-total">
          <strong>Total: ₹<%= total.toLocaleString('en-IN') %></strong>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer"><p>© 2024 ShopEase</p></footer>
  <script src="/js/main.js"></script>
</body>
</html>
